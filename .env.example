# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it, never include it in a shared zip.
#
# Currently the deployed demo runs entirely on the LOCAL AI-like summary
# (generate_ai_summary.py) and does NOT require any API key.
#
# The OpenAI integration (generate_ai_summary_api.py) is disabled by default
# and only activates if you explicitly switch to the API path AND the value
# below is set.

OPENAI_API_KEY=your-openai-api-key-here
